# Copy this file to .env and fill in the values.
# Never commit your real .env to version control.

# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_PORT=8080
DEBUG=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=playground_db
DB_USER=postgres
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# External APIs (placeholders)
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
SENDGRID_API_KEY=
