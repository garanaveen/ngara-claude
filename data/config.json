{
  "app": {
    "name": "ngara-playground",
    "version": "1.0.0",
    "debug": false,
    "log_level": "info"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "workers": 4,
    "timeout_seconds": 30
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "playground_db",
    "pool_size": 10,
    "ssl": false
  },
  "cache": {
    "backend": "redis",
    "host": "localhost",
    "port": 6379,
    "ttl_seconds": 300
  },
  "features": {
    "enable_analytics": true,
    "enable_notifications": false,
    "beta_ui": false
  }
}
